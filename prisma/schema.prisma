generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

model Empresa {
  id                   Int                  @id @default(autoincrement()) @map("id") @db.UnsignedInt
  codigo               String               @unique(map: "codigo") @map("codigo") @db.VarChar(50)
  nombre               String               @map("nombre") @db.VarChar(255)
  razonSocial          String               @map("razon_social") @db.VarChar(255)
  cuit                 String?              @map("cuit") @db.VarChar(20)
  sfactoryCompanyKey   String               @map("sfactory_company_key") @db.VarChar(255)
  sfactoryUserId       Int?                 @map("sfactory_user_id")
  sfactoryToken        String?              @map("sfactory_token") @db.Text
  sfactoryTokenExpiry  DateTime?            @map("sfactory_token_expiry") @db.Timestamp(0)
  sfactoryCompanyId    Int?                 @map("sfactory_company_id")
  activa               Boolean              @default(true) @map("activa")
  logoUrl              String?              @map("logo_url") @db.VarChar(500)
  colores              Json?                @map("colores")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  camposPersonalizados CampoPersonalizado[]
  clientes             Cliente[]
  pedidos              Pedido[]
  productosPadre       ProductoPadre[]
  productosWeb         ProductoWeb[]
  productosSfactory    ProductoSfactory[]  @relation("ProductoSfactoryEmpresa")
  reglasParseo         ReglaParseo[]
  rubros               Rubro[]
  subrubros            Subrubro[]
  syncLogs             SyncLog[]
  usuarios             Usuario[]

  @@index([codigo], map: "idx_codigo")
  @@index([activa], map: "idx_activa")
  @@map("empresas")
}

model Role {
  id        Int       @id @default(autoincrement()) @map("id") @db.UnsignedInt
  code      String    @unique(map: "code") @map("code") @db.VarChar(20)
  name      String?   @map("name") @db.VarChar(50)
  usuarios  Usuario[]

  @@map("roles")
}

model Usuario {
  id                Int         @id @default(autoincrement()) @map("id") @db.UnsignedInt
  externalId        String?     @unique(map: "auth0_user_id") @map("auth0_user_id") @db.VarChar(255)
  empresaId         Int?        @map("empresa_id") @db.UnsignedInt
  email             String      @unique(map: "email") @map("email") @db.VarChar(255)
  rol               Rol         @default(cliente) @map("rol")
  roleId            Int?        @map("role_id") @db.UnsignedInt
  role              Role?       @relation(fields: [roleId], references: [id], onUpdate: NoAction, map: "usuarios_role_fk")
  provider          String?     @map("provider") @db.VarChar(50)
  nombre            String      @map("nombre") @db.VarChar(255)
  apellido          String?     @map("apellido") @db.VarChar(255)
  telefono          String?     @map("telefono") @db.VarChar(50)
  avatarUrl         String?     @map("avatar_url") @db.VarChar(500)
  passwordHash      String?     @map("password_hash") @db.VarChar(255)
  isSystemUser          Boolean     @default(false) @map("is_system_user")
  emailVerified         Boolean     @default(false) @map("email_verified")
  onboardingCompleted   Boolean     @default(false) @map("onboarding_completed")
  fechaNacimiento       DateTime?   @map("fecha_nacimiento") @db.Date
  sfactoryClienteId     Int?        @unique(map: "sfactory_cliente_id") @map("sfactory_cliente_id")
  activo                Boolean     @default(true) @map("activo")
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  pedidos               Pedido[]
  sesiones              Sesion[]
  authTokens            AuthToken[]
  cliente               Cliente?
  empresa               Empresa?   @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "usuarios_ibfk_1")

  @@index([email], map: "idx_email")
  @@index([empresaId, rol], map: "idx_empresa_rol")
  @@index([externalId], map: "idx_auth0")
  @@index([roleId], map: "idx_role_id")
  @@map("usuarios")
}

model Rubro {
  id                        Int             @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId                 Int             @map("empresa_id") @db.UnsignedInt
  sfactoryId                Int             @map("sfactory_id")
  sfactoryCodigo            String?         @map("sfactory_codigo") @db.VarChar(50)
  nombre                    String          @map("nombre") @db.VarChar(255)
  codigoExterno             String?         @map("codigo_externo") @db.VarChar(100)
  visibleWeb                Boolean         @default(true) @map("visible_web")
  orden                     Int             @default(0) @map("orden")
  slug                      String?         @map("slug") @db.VarChar(255)
  descripcionWeb            String?         @map("descripcion_web") @db.Text
  imagenUrl                 String?         @map("imagen_url") @db.VarChar(500)
  ultimaSync                DateTime?       @map("ultima_sync") @db.Timestamp(0)
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                 DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  productosPadre            ProductoPadre[]
  productosSfactory         ProductoSfactory[] @relation("ProductoSfactoryRubro")
  reglasParseoAplicarARubro ReglaParseo[]   @relation("RubroReglasParseo")
  empresa                   Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rubros_ibfk_1")
  subrubros                 Subrubro[]

  @@unique([empresaId, sfactoryId], name: "unique_empresa_sfactory", map: "unique_empresa_sfactory")
  @@index([empresaId, visibleWeb], map: "idx_visible")
  @@index([slug], map: "idx_slug")
  @@map("rubros")
}

model Subrubro {
  id                           Int             @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId                    Int             @map("empresa_id") @db.UnsignedInt
  rubroId                      Int             @map("rubro_id") @db.UnsignedInt
  sfactoryId                   Int             @map("sfactory_id")
  sfactoryCodigo               String?         @map("sfactory_codigo") @db.VarChar(50)
  sfactoryRubroId              Int             @map("sfactory_rubro_id")
  nombre                       String          @map("nombre") @db.VarChar(255)
  codigoExterno                String?         @map("codigo_externo") @db.VarChar(100)
  visibleWeb                   Boolean         @default(true) @map("visible_web")
  orden                        Int             @default(0) @map("orden")
  slug                         String?         @map("slug") @db.VarChar(255)
  descripcionWeb               String?         @map("descripcion_web") @db.Text
  imagenUrl                    String?         @map("imagen_url") @db.VarChar(500)
  ultimaSync                   DateTime?       @map("ultima_sync") @db.Timestamp(0)
  createdAt                    DateTime        @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                    DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  productosPadre               ProductoPadre[]
  productosSfactory            ProductoSfactory[] @relation("ProductoSfactorySubrubro")
  reglasParseoAplicarASubrubro ReglaParseo[]   @relation("SubrubroReglasParseo")
  empresa                      Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subrubros_ibfk_1")
  rubro                        Rubro           @relation(fields: [rubroId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subrubros_ibfk_2")

  @@unique([empresaId, sfactoryId], name: "unique_empresa_sfactory", map: "unique_empresa_sfactory")
  @@index([rubroId], map: "idx_rubro")
  @@index([empresaId, visibleWeb], map: "idx_visible")
  @@index([slug], map: "idx_slug")
  @@map("subrubros")
}

model ProductoPadre {
  id                   Int            @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId            Int            @map("empresa_id") @db.UnsignedInt
  codigoAgrupacion     String         @map("codigo_agrupacion") @db.VarChar(100)
  nombre               String         @map("nombre") @db.VarChar(500)
  descripcion          String?        @map("descripcion") @db.Text
  agrupacionTipo       AgrupacionTipo @default(automatico) @map("agrupacion_tipo")
  agrupacionConfirmada Boolean        @default(false) @map("agrupacion_confirmada")
  rubroId              Int?           @map("rubro_id") @db.UnsignedInt
  subrubroId           Int?           @map("subrubro_id") @db.UnsignedInt
  linea                String?        @map("linea") @db.VarChar(255)
  material             String?        @map("material") @db.VarChar(255)
  um                   String?        @map("um") @db.VarChar(50)
  publicado            Boolean        @default(false) @map("publicado")
  destacado            Boolean        @default(false) @map("destacado")
  orden                Int            @default(0) @map("orden")
  descripcionMarketing String?        @map("descripcion_marketing") @db.Text
  descripcionCorta     String?        @map("descripcion_corta") @db.VarChar(500)
  slug                 String?        @unique(map: "slug") @map("slug") @db.VarChar(255)
  genero               String?        @map("genero") @db.VarChar(20)
  metaTitle            String?        @map("meta_title") @db.VarChar(255)
  metaDescription      String?        @map("meta_description") @db.VarChar(500)
  imagenes             Json?          @map("imagenes")
  videoUrl             String?        @map("video_url") @db.VarChar(500)
  fichaTecnicaUrl      String?        @map("ficha_tecnica_url") @db.VarChar(500)
  tablaTallesUrl       String?        @map("tabla_talles_url") @db.VarChar(500)
  camposPersonalizados Json?          @map("campos_personalizados")
  coloresDisponibles   Json?          @map("colores_disponibles")
  tallesDisponibles    Json?          @map("talles_disponibles")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  pedidosItems         PedidoItem[]
  empresa              Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "productos_padre_ibfk_1")
  rubro                Rubro?         @relation(fields: [rubroId], references: [id], onUpdate: NoAction, map: "productos_padre_ibfk_2")
  subrubro             Subrubro?      @relation(fields: [subrubroId], references: [id], onUpdate: NoAction, map: "productos_padre_ibfk_3")
  productosWeb         ProductoWeb[]

  @@unique([empresaId, codigoAgrupacion], name: "unique_empresa_agrupacion", map: "unique_empresa_agrupacion")
  @@index([empresaId, publicado], map: "idx_publicado")
  @@index([empresaId, publicado, genero], map: "idx_empresa_publicado_genero")
  @@index([empresaId, publicado, destacado], map: "idx_empresa_publicado_destacado")
  @@index([empresaId, publicado, rubroId], map: "idx_empresa_publicado_rubro")
  @@index([empresaId, publicado, subrubroId], map: "idx_empresa_publicado_subrubro")
  @@index([destacado], map: "idx_destacado")
  @@index([rubroId], map: "idx_rubro")
  @@index([subrubroId], map: "idx_subrubro")
  @@index([slug, empresaId], map: "idx_slug_empresa")
  @@index([empresaId, codigoAgrupacion], map: "idx_empresa_agrupacion")
  @@map("productos_padre")
}

model ProductoWeb {
  id                  Int              @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId           Int              @map("empresa_id") @db.UnsignedInt
  productoPadreId     Int              @map("producto_padre_id") @db.UnsignedInt
  sfactoryId          Int              @map("sfactory_id")
  sfactoryCodigo      String           @map("sfactory_codigo") @db.VarChar(100)
  sfactoryBarcode     String?          @map("sfactory_barcode") @db.VarChar(100)
  nombre              String           @map("nombre") @db.VarChar(500)
  descripcionCompleta String?          @map("descripcion_completa") @db.VarChar(500)
  sexo                String?          @map("sexo") @db.VarChar(20)
  talle               String?          @map("talle") @db.VarChar(50)
  color               String?          @map("color") @db.VarChar(100)
  precioCache         Decimal?         @map("precio_cache") @db.Decimal(10, 2)
  stockCache          Decimal?         @map("stock_cache") @db.Decimal(10, 2)
  ultimaSyncSfactory  DateTime?        @map("ultima_sync_sfactory") @db.Timestamp(0)
  activoSfactory      Boolean          @default(true) @map("activo_sfactory")
  imagenVariante      String?          @map("imagen_variante") @db.VarChar(500)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  pedidosItems        PedidoItem[]
  imagenes            ProductoImagen[]
  empresa             Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "productos_web_ibfk_1")
  productoPadre       ProductoPadre    @relation(fields: [productoPadreId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "productos_web_ibfk_2")
  precios             ProductoPrecio[]

  @@unique([empresaId, sfactoryCodigo], name: "unique_empresa_sfactory", map: "unique_empresa_sfactory")
  @@index([productoPadreId], map: "idx_producto_padre")
  @@index([productoPadreId, activoSfactory], map: "idx_padre_activo")
  @@index([empresaId, activoSfactory], map: "idx_empresa_activo")
  @@index([empresaId, activoSfactory, sexo], map: "idx_empresa_activo_sexo")
  @@index([empresaId, activoSfactory, color], map: "idx_empresa_activo_color")
  @@index([empresaId, activoSfactory, talle], map: "idx_empresa_activo_talle")
  @@index([empresaId, activoSfactory, stockCache], map: "idx_empresa_activo_stock")
  @@index([sfactoryId], map: "idx_sfactory_id")
  @@index([talle], map: "idx_talle")
  @@index([color], map: "idx_color")
  @@index([sexo], map: "idx_sexo")
  @@index([stockCache], map: "idx_stock")
  @@map("productos_web")
}

model ProductoImagen {
  id            Int         @id @default(autoincrement()) @map("id") @db.UnsignedInt
  productoWebId Int         @map("producto_web_id") @db.UnsignedInt
  color         String?     @map("color") @db.VarChar(100)
  imagenUrl     String      @map("imagen_url") @db.VarChar(500)
  orden         Int         @default(1) @map("orden")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  productoWeb   ProductoWeb @relation(fields: [productoWebId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "producto_imagenes_ibfk_1")

  @@index([productoWebId], map: "idx_producto_web")
  @@index([color], map: "idx_color")
  @@map("producto_imagenes")
}

model ProductoPrecio {
  id             Int         @id @default(autoincrement())
  productoWebId  Int         @map("producto_web_id") @db.UnsignedInt
  tipoCliente    TipoCliente @map("tipo_cliente")
  precio         Decimal     @db.Decimal(10, 2)
  precioLista    Decimal     @map("precio_lista") @db.Decimal(10, 2)
  precioTransfer Decimal?    @map("precio_transfer") @db.Decimal(10, 2)
  precioFinanciado Decimal?  @map("precio_financiado") @db.Decimal(10, 2)
  cuotasFinanciado Int?      @map("cuotas_financiado") @default(3) @db.UnsignedInt
  precioSinImp   Decimal?    @map("precio_sin_imp") @db.Decimal(10, 2)
  minimoUnidades Decimal?    @db.Decimal(10, 2)

  productoWeb ProductoWeb @relation(fields: [productoWebId], references: [id], onDelete: Cascade)

  @@unique([productoWebId, tipoCliente], name: "unique_producto_tipo")
  @@index([tipoCliente], map: "idx_tipo_cliente")
  @@map("productos_precios")
}

model ProductoSfactory {
  id                   Int       @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId            Int       @map("empresa_id") @db.UnsignedInt
  codigo               String    @map("codigo") @db.VarChar(50)
  barcode              String?   @map("barcode") @db.VarChar(50)
  descrip_corta        String?   @map("descrip_corta") @db.Text
  descripcion          String?   @map("descripcion") @db.Text
  detalle              String?   @map("detalle") @db.Text
  tipo                 String?   @map("tipo") @db.VarChar(5)
  stockeable           String?   @map("stockeable") @db.VarChar(5)
  stock_minimo         Decimal?  @map("stock_minimo") @db.Decimal(10,2)
  stock_maximo         Decimal?  @map("stock_maximo") @db.Decimal(10,2)
  precio_costo         Decimal?  @map("precio_costo") @db.Decimal(10,2)
  precio_venta         Decimal?  @map("precio_venta") @db.Decimal(10,2)
  iva                  Decimal?  @map("iva") @db.Decimal(5,2)
  utilidad_planificada Decimal?  @map("utilidad_planificada") @db.Decimal(10,2)
  utilidad_real        Decimal?  @map("utilidad_real") @db.Decimal(10,2)
  rubro                String?   @map("rubro") @db.VarChar(100)
  subrubro             String?   @map("subrubro") @db.VarChar(100)
  rubro_id             Int?      @map("rubro_id") @db.UnsignedInt
  subrubro_id          Int?      @map("subrubro_id") @db.UnsignedInt
  item_venta           String?   @map("item_venta") @db.VarChar(5)
  item_compra          String?   @map("item_compra") @db.VarChar(5)
  item_alquiler        String?   @map("item_alquiler") @db.VarChar(5)
  cta_ingresos_id      Int?      @map("cta_ingresos_id")
  cta_egresos_id       Int?      @map("cta_egresos_id")
  cta_costo_venta_id   Int?      @map("cta_costo_venta_id")
  codigo_externo       String?   @map("codigo_externo") @db.VarChar(50)
  ctb_id               Int?
  peso_bruto           Decimal?  @map("peso_bruto") @db.Decimal(10,2)
  volumen              Decimal?  @map("volumen") @db.Decimal(10,2)
  ancho                Decimal?  @map("ancho") @db.Decimal(10,2)
  largo                Decimal?  @map("largo") @db.Decimal(10,2)
  activo               String?   @map("activo") @db.VarChar(5)
  um                   String?   @map("um") @db.VarChar(10)
  um_compra            String?   @map("um_compra") @db.VarChar(10)
  um_id                Int?
  um_compra_id         Int?
  precio_um_compra     Decimal?  @map("precio_um_compra") @db.Decimal(10,2)
  extcode_2            String?   @map("extcode_2") @db.VarChar(50)
  moneda               String?   @map("moneda") @db.VarChar(5)
  fecha_act_precio     DateTime? @map("fecha_act_precio") @db.Timestamp(0)
  generico             String?   @map("generico") @db.VarChar(5)
  grupo_gasto          String?   @map("grupo_gasto") @db.VarChar(100)
  lista_material       String?   @map("lista_material") @db.Text
  deposito_consumo     String?   @map("deposito_consumo") @db.VarChar(50)
  item_lote            String?   @map("item_lote") @db.VarChar(5)
  item_serie           String?   @map("item_serie") @db.VarChar(5)
  fabricar             String?   @map("fabricar") @db.VarChar(5)
  a_pedido             String?   @map("a_pedido") @db.VarChar(5)
  clase                String?   @map("clase") @db.VarChar(50)
  linea                String?   @map("linea") @db.VarChar(100)
  material             String?   @map("material") @db.VarChar(100)
  proveedor            String?   @map("proveedor") @db.VarChar(100)
  precio_costo_xlm     Decimal?  @map("precio_costo_xlm") @db.Decimal(10,2)
  flowint_sincro_enabled String? @map("flowint_sincro_enabled") @db.VarChar(5)
  deposito_ubicacion   String?   @map("deposito_ubicacion") @db.VarChar(50)
  actualizar_precio_xoc String?  @map("actualizar_precio_xoc") @db.VarChar(5)
  fecha_alta           DateTime? @map("fecha_alta") @db.Timestamp(0)
  usuario              String?   @map("usuario") @db.VarChar(100)
  sfactory_id          Int?      @map("sfactory_id")
  ultima_sync          DateTime? @map("ultima_sync") @db.Timestamp(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relaciones
  empresa    Empresa      @relation("ProductoSfactoryEmpresa", fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rubroRel   Rubro?       @relation("ProductoSfactoryRubro", fields: [rubro_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  subrubroRel Subrubro?   @relation("ProductoSfactorySubrubro", fields: [subrubro_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([empresaId, codigo], name: "unique_empresa_codigo")
  @@index([empresaId], map: "idx_empresa")
  @@index([empresaId, codigo], map: "idx_empresa_codigo")
  @@index([empresaId, rubro_id], map: "idx_empresa_rubro")
  @@index([empresaId, subrubro_id], map: "idx_empresa_subrubro")
  @@index([rubro_id], map: "idx_rubro")
  @@index([subrubro_id], map: "idx_subrubro")
  @@index([codigo], map: "idx_codigo")
  @@index([ultima_sync], map: "idx_ultima_sync")
  @@map("productos_sfactory")
}
model ReglaParseo {
  id                 Int       @id @default(autoincrement()) @map("id") @db.UnsignedInt
  empresaId          Int       @map("empresa_id") @db.UnsignedInt
  nombreRegla        String    @map("nombre_regla") @db.VarChar(255)
  patronRegex        String?   @map("patron_regex") @db.VarChar(500)
  posicionNombre     String?   @map("posicion_nombre") @db.VarChar(100)
  posicionColor      String?   @map("posicion_color") @db.VarChar(100)
  posicionTalle      String?   @map("posicion_talle") @db.VarChar(100)
  aplicarARubroId    Int?      @map("aplicar_a_rubro_id") @db.UnsignedInt
  aplicarASubrubroId Int?      @map("aplicar_a_subrubro_id") @db.UnsignedInt
  aplicarALinea      String?   @map("aplicar_a_linea") @db.VarChar(255)
  activa             Boolean   @default(true) @map("activa")
  prioridad          Int       @default(0) @map("prioridad")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  empresa            Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reglas_parseo_ibfk_1")
  aplicarARubro      Rubro?    @relation("RubroReglasParseo", fields: [aplicarARubroId], references: [id], onUpdate: NoAction, map: "reglas_parseo_ibfk_2")
  aplicarASubrubro   Subrubro? @relation("SubrubroReglasParseo", fields: [aplicarASubrubroId], references: [id], onUpdate: NoAction, map: "reglas_parseo_ibfk_3")

  @@index([empresaId, activa], map: "idx_empresa_activa")
  @@index([aplicarARubroId], map: "aplicar_a_rubro_id")
  @@index([aplicarASubrubroId], map: "aplicar_a_subrubro_id")
